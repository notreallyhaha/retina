{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs-18_x"]
        },
        "install": {
          "cmds": ["cd server && npm install --production"]
        }
      },
      "start": {
        "cmd": "cd server && node index.js"
      }
    }
  },
  "deploy": {
    "startCommand": "cd server && node index.js",
    "healthcheck": {
      "path": "/health",
      "timeout": 30,
      "interval": 10
    }
  }
}
